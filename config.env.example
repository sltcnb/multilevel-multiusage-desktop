# config.env.example
# -----------------------------------------------------------------------------
# This file is a template. The scripts (starting with host/detect-and-install.sh)
# auto-detect hardware and WRITE the real values into ./config.env, which every
# later script sources. You normally do NOT edit config.env by hand — but any
# value below can be overridden by exporting it before running the scripts, or
# by editing config.env after it is generated.
#
# All values here are OVERRIDABLE TUNABLES. Auto-detected values are marked.
# -----------------------------------------------------------------------------

# --- Disk encryption (OPTIONAL, EXPERIMENTAL) --------------------------------
# ENCRYPT=1 makes installer/install-to-disk.sh do a LUKS2 encrypted install (root
# encrypted at rest; passphrase entered at each boot). Default 0 = plaintext
# dd-clone (fast, well-tested). Test ENCRYPT=1 on a spare/VM before relying on
# it — a bad encrypted install can be unbootable. TPM2 auto-unlock is a TODO.
ENCRYPT=0
LUKS_PASS=""          # REQUIRED when ENCRYPT=1. Sensitive — an image with this
                      # baked in is a secret; prefer setting it on the appliance.

# --- Paths -------------------------------------------------------------------
# Where VM disk images live. Auto-detected in host/detect-and-install.sh (defaults to libvirt default).
IMAGES_DIR="/var/lib/libvirt/images"
# Where downloaded cloud images / ISOs are cached.
CACHE_DIR="/var/cache/appliance-build"

# --- Hardware (AUTO-DETECTED — do not hardcode; shown here for reference) -----
# CPU_VENDOR      -> "intel" or "amd"        (from /proc/cpuinfo)
# KVM_MODULE      -> "kvm_intel" or "kvm_amd"
# NESTED_PARAM    -> module param line for nested virt
# TOTAL_CORES     -> nproc
# TOTAL_RAM_MB    -> /proc/meminfo MemTotal
# DISK_FREE_MB    -> free space on IMAGES_DIR filesystem

# --- Host headroom (OVERRIDABLE) ---------------------------------------------
# RAM/cores/disk reserved for the host itself, never given to VMs.
HOST_RESERVE_RAM_MB=2048
HOST_RESERVE_CORES=1
HOST_RESERVE_DISK_MB=4096     # 4 GiB kept free on IMAGES_DIR for the host
                              # (keep small; VM storage should live on a big
                              # disk via IMAGES_DIR, not the boot USB)
# Warn if free disk on IMAGES_DIR drops below this (MB).
DISK_LOW_WATERMARK_MB=40960   # 40 GiB

# =============================================================================
# ENVIRONMENTS (the VMs). Ordered list; position (1-based) fixes each env's
# workspace number, /24 subnet and bridge, so enabling/disabling one never
# renumbers the others. English names: office / development / administration
# (bureautique / développement / administration).
# =============================================================================
ENVS="office development administration"
SUBNET_BASE="10.10"          # env at index i uses ${SUBNET_BASE}.i.0/24

# Per-env settings ------------------------------------------------------------
#   <env>_ENABLED  1|0   create + show this environment?
#   <env>_OS       ubuntu|arch|debian   guest OS. NOTE: the office/desktop env
#                  MUST be ubuntu (Intune/Entra enrollment is Ubuntu-only).
#   <env>_DE       xfce4|gnome|kde|mate|lxqt|none   desktop env (all distros;
#                  cloud-init installs it + display manager + autologin). "none"=CLI.
#   <env>_EGRESS_MODE  all|whitelist ; <env>_EGRESS_ALLOW "ip ip"
#   <env>_INTUNE   1  (Ubuntu only) install MS Intune portal for Entra enrollment
#   <env>_MSAPPS   1  install Outlook + Teams as Edge PWAs (Conditional-Access ok)
#   <env>_WAZUH    1  install + enroll the Wazuh agent (needs WAZUH_MANAGER below)

# office = bureautique (daily desktop). Ubuntu (required for Entra/Intune).
office_ENABLED=1
office_OS="ubuntu"
office_DE="gnome"
office_EGRESS_MODE="all";          office_EGRESS_ALLOW=""
office_INTUNE=1                    # register to Intune/Entra (interactive after boot)
office_MSAPPS=1                    # Outlook + Teams (Edge PWAs)

# development = développement. Arch by default; monitored by Wazuh.
development_ENABLED=1
development_OS="arch"
development_DE="gnome"
development_EGRESS_MODE="all";     development_EGRESS_ALLOW=""
development_WAZUH=1

# administration = administration (sensitive). Arch; monitored by Wazuh. Example
# egress lockdown shown (flip MODE to whitelist to only allow DNS + listed hosts).
administration_ENABLED=1
administration_OS="arch"
administration_DE="gnome"
administration_EGRESS_MODE="all";  administration_EGRESS_ALLOW="1.1.1.1 8.8.8.8"
administration_WAZUH=1

# Wazuh manager (server) IP/hostname — REQUIRED for any env with <env>_WAZUH=1.
WAZUH_MANAGER=""

# --- Per-env dedicated, non-bypassable VPN (ANSSI #8) — OPT-IN, EXPERIMENTAL --
# Set <env>_VPN=1 and fill the WireGuard fields, then run environments/vpn.sh.
# The tunnel is enforced on the HOST (policy routing + nftables), so the guest
# cannot disable/bypass it. Needs a real WireGuard peer + on-hardware testing.
# PRIVKEY is SENSITIVE — prefer setting these on the appliance, not in the image.
#   <env>_VPN=1
#   <env>_VPN_PRIVKEY="<host private key>"
#   <env>_VPN_ADDRESS="10.9.<idx>.2/32"
#   <env>_VPN_PUBKEY="<peer/gateway public key>"
#   <env>_VPN_ENDPOINT="vpn.example.com:51820"
#   <env>_VPN_ALLOWED="0.0.0.0/0"     # full tunnel
office_VPN=0
development_VPN=0
administration_VPN=0

# --- Disk auto-split ---------------------------------------------------------
# AUTO_DISK=1 (default): 01 splits detected free space evenly across the ENABLED
#   envs (qcow2 thin -> these are MAX virtual sizes). AUTO_DISK=0 uses the fixed
#   per-env size below.
AUTO_DISK=1
FIXED_DISK_GB=30             # used per env only when AUTO_DISK=0

# --- Per-env user-keyed disk encryption (ANSSI) — OPT-IN, EXPERIMENTAL --------
# <env>_ENCRYPT_DISK=1 makes that VM's disk a LUKS-encrypted qcow2, unlocked by
# <env>_DISK_PASS (a secret the user knows). libvirt holds the secret to start
# the domain; scrub-secrets.sh blanks <env>_DISK_PASS from config afterward.
#   <env>_ENCRYPT_DISK=1
#   <env>_DISK_PASS="a-strong-per-env-passphrase"
office_ENCRYPT_DISK=0
development_ENCRYPT_DISK=0
administration_ENCRYPT_DISK=0

# --- USB peripheral lockdown (ANSSI #9) (OVERRIDABLE) ------------------------
# 1 = enable usbguard (default-deny USB; allow-policy generated on first boot so
#     built-in keyboard/trackpad keep working). Bind a device to one VM at a time
#     with `virsh attach-device`. 0 = off (hot-plug USB works freely).
# WARNING: with 1, a USB device plugged AFTER first boot is blocked until allowed
# (`usbguard list-devices` / `usbguard allow-device <id>`).
USBGUARD=1

# --- YubiKey -> VM routing (OVERRIDABLE) -------------------------------------
# 1 = on plug you CHOOSE which VM gets the YubiKey; it is USB-passed-through to
#     ONLY that env (detached from any other first — never shared across envs).
#     usbguard is told to admit Yubico (vendor 1050); a udev rule pops the chooser
#     on insert; Super+y re-runs it manually. Needs USBGUARD=1 to matter.
# 0 = no special YubiKey handling.
YUBIKEY_ROUTER=1

# --- Host (socle) hardening (ANSSI #2) (OVERRIDABLE) -------------------------
# Kernel sysctl hardening is always applied by host/harden.sh. The host INPUT
# firewall (default-drop everything TO the host) is opt-in so it can't lock out
# an SSH you use during setup.
HARDEN_INPUT=0        # 1 = default-drop host INPUT (socle exposes no services)
HOST_SSH=0            # 1 = keep sshd reachable (port 22) when HARDEN_INPUT=1

# --- Trust bar (ANSSI barre de confiance) (OVERRIDABLE) ----------------------
# 1 = always-visible top bar showing the active environment (color-coded);
#     guests tile below it so it can't be hidden. ANSSI requires the user to
#     always know which environment is active.
# 0 = guests go true fullscreen edge-to-edge, no persistent bar.
TRUST_BAR=1

# --- Guest OS variants + image URLs (OVERRIDABLE) ----------------------------
# Run `osinfo-query os` for valid --os-variant values.
UBUNTU_OS_VARIANT="ubuntu22.04"
ARCH_OS_VARIANT="archlinux"
DEBIAN_OS_VARIANT="debian12"

# --- Base image integrity pinning (REQUIRED per enabled OS) ------------------
# environments/create.sh downloads the base cloud images above over plain
# HTTPS with no signature check of its own. It FAILS CLOSED: it refuses to use
# a downloaded (or already-cached) image unless its SHA256 matches EXACTLY
# what you pin here, for every OS an ENABLED env actually uses. Leave the ones
# you don't need empty.
#   1. Fetch the vendor's own published checksums (ideally over a path/network
#      independent from this host) and verify THEIR signature before trusting
#      them:
#        Ubuntu:  https://cloud-images.ubuntu.com/jammy/current/SHA256SUMS
#                 (+ SHA256SUMS.gpg, signed by Canonical's image key)
#        Arch:    https://geo.mirror.pkgbuild.com/images/latest/sha256sums.txt
#                 (+ .sig, signed by the Arch Linux release key)
#        Debian:  https://cloud.debian.org/images/cloud/bookworm/latest/SHA256SUMS
#                 (+ SHA256SUMS.sign, signed by the Debian cloud image key)
#   2. Paste the matching 64-hex-char digest below.
# These upstream URLs serve "latest"/"current" rolling images, so a pinned
# hash WILL go stale when the vendor publishes a new build — that is
# intentional (fail closed): re-verify + update it then, don't blank it out.
UBUNTU_IMG_SHA256=""
ARCH_IMG_SHA256=""
DEBIAN_IMG_SHA256=""

# --- Pinned GPG fingerprints for in-guest third-party repos (OVERRIDABLE) ----
# Microsoft Intune/Edge and the Wazuh agent are installed inside guests via
# `curl <key-url> | gpg --dearmor`. create.sh pins each vendor's signing-key
# fingerprint and makes the guest verify the ACTUALLY downloaded key against
# it before trusting it (aborts that install on any mismatch — fail closed).
# Defaults below are the vendors' current, well-known, long-lived signing keys
# (independently verified against packages.microsoft.com / packages.wazuh.com).
# Only override if a vendor rotates its key — verify the new fingerprint
# out-of-band first, e.g. via the vendor's own docs over an independent path.
MS_GPG_FPR="BC528686B50D79E339D3721CEB3E94ADBE1229CF"
WAZUH_GPG_FPR="0DCFCA5547B19D2A6099506096B3EE5F29111145"

# --- Host users (OVERRIDABLE) ------------------------------------------------
# The desktop autologins an UNPRIVILEGED user that can only view/launch the VMs
# (member of libvirt/kvm, no sudo). Root is reserved for admin on tty2 (Ctrl+Alt+F2).
KIOSK_USER="kiosk"
# Host keyboard layout for the desktop (X). e.g. us, fr, de, gb, be, ch, es ...
# Optional variant after a colon, e.g. "fr:oss" or "us:intl".
KEYBOARD_LAYOUT="us"
# Root (admin) password. Set a value, or "generate" to auto-generate a strong one
# (recorded in /root/generated-secrets.txt on the appliance). Also settable to "".
HOST_ROOT_PASSWORD="changeme-root"

# -----------------------------------------------------------------------------
# SECRETS THAT CAN BE AUTO-GENERATED
# Set any of these to "generate" (or leave empty) and the scripts create a strong
# random value at provisioning, save it to /root/generated-secrets.txt, and use it:
#   HOST_ROOT_PASSWORD  (host/configure.sh)   root admin password
#   GUEST_PASSWORD      (environments/create.sh) guest login password
#   LUKS_PASS           (installer/install-to-disk.sh) full-disk LUKS passphrase
#   <env>_DISK_PASS     (environments/create.sh) per-env LUKS passphrase
# WireGuard keys (<env>_VPN_PRIVKEY) are NOT random blobs — generate with
# `wg genkey` and set explicitly. All generated secrets are blanked from
# config.env by environments/scrub-secrets.sh once consumed.
# -----------------------------------------------------------------------------

# --- Guest credentials (OVERRIDABLE — CHANGE THESE) --------------------------
# Used by cloud-init. Password login enabled for console access via virt-viewer.
GUEST_USER="operator"
# Plaintext here for convenience; scripts hash/pass it to cloud-init. CHANGE IT.
GUEST_PASSWORD="changeme"

# Uplink interface for NAT masquerade. AUTO-DETECTED in environments/isolate.sh if left "auto".
WAN_IFACE="auto"

# --- Per-env outbound (egress) policy ----------------------------------------
# Set per env above via <env>_EGRESS_MODE / <env>_EGRESS_ALLOW.
#   "all"       = full outbound internet via NAT (default).
#   "whitelist" = only DNS + listed IPs/CIDRs; everything else from that env is
#                 dropped. (names not supported by nftables — use a proxy; see
#                 README design note 1.)

# --- WiFi uplink (OVERRIDABLE; leave SSID empty to keep host on wired) --------
# If WIFI_SSID is non-empty, host/wifi.sh (and first-boot) will bring up
# WiFi as the host uplink. WAN_IFACE="auto" then resolves to the wlan iface.
# SECURITY: PSK is hashed with wpa_passphrase before writing; plaintext is not
# stored in wpa_supplicant.conf. Still, an image built with these set is
# sensitive — treat it as a secret. Prefer leaving them empty and running 06
# interactively on the appliance.
WIFI_SSID=""
WIFI_PSK=""
WIFI_COUNTRY="FR"          # regulatory domain (ISO 3166-1 alpha-2)
WIFI_IFACE="auto"          # "auto" = first wlan* interface
# Firmware package baked into the image (see 00/01). "linux-firmware" = all
# blobs (safe for unknown NIC); narrow to e.g. linux-firmware-iwlwifi to shrink.
WIFI_FIRMWARE_PKG="linux-firmware"
